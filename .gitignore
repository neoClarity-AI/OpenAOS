# AOS instance folders — never commit user instances to this factory repo
# (anchored to repo root so it doesn't also match nested build artifacts,
# e.g. claude-plugin/aos-factory/skills/build-aos/)
/*-aos/
!/aos-factory/

# Common OS and editor files
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
.claude/

# Logs that may contain personal data
*.log

# Temp/scratch/zip files
*.tmp
*.bak
*.zip

# Internal documents
internal-only/
